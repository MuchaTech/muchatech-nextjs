# ─── PayFast ──────────────────────────────────────────────────────
# Get these from your PayFast merchant dashboard:
# https://www.payfast.co.za/merchant/settings

# Sandbox credentials (default — safe for dev/testing)
NEXT_PUBLIC_PAYFAST_MERCHANT_ID=10000100
NEXT_PUBLIC_PAYFAST_MERCHANT_KEY=46f0cd694581a
NEXT_PUBLIC_PAYFAST_PASSPHRASE=

# Set to false in production!
NEXT_PUBLIC_PAYFAST_SANDBOX=true

# ─── Site URL ─────────────────────────────────────────────────────
# Used for return/cancel/notify URLs sent to PayFast.
# Must be a publicly accessible URL in production (ngrok works for local testing).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── For ITN webhook (notify_url) ─────────────────────────────────
# In production: your deployed URL, e.g. https://muchatech.com
# For local testing: use ngrok → ngrok http 3000
# Then set NEXT_PUBLIC_SITE_URL=https://YOUR-NGROK-ID.ngrok.io

# ─── Admin Authentication ──────────────────────────────────────
# ADMIN_PASSWORD — the password you type on the login screen
# ADMIN_SESSION_TOKEN — a random secret used to sign the session
#   cookie. Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD=change-me-before-deploying
ADMIN_SESSION_TOKEN=generate-a-random-64-char-hex-string-here
